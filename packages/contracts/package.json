{
  "name": "@cleocode/contracts",
  "version": "2026.4.85",
  "description": "Domain types, interfaces, and contracts for the CLEO ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b --force && node scripts/emit-schemas.mjs",
    "build:ts": "tsc -b --force",
    "build:schemas": "node scripts/emit-schemas.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "schemas",
    "src"
  ],
  "devDependencies": {
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kryptobaseddev/cleo",
    "directory": "packages/contracts"
  },
  "dependencies": {
    "zod-to-json-schema": "^3.25.2"
  }
}
