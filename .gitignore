node_modules/
dist/
*.tsbuildinfo
.pnpm-debug.log
coverage/
.test-*

# ---------------------------------------------------------------------------
# CLEO runtime data — NEVER track (ADR-013 §9, T5158)
# ---------------------------------------------------------------------------
# Runtime databases corrupt on branch switch because of WAL-mode sidecar
# files. Config + project-info are regenerated from defaults by `cleo init`.
# Recovery is provided by VACUUM INTO snapshots at .cleo/backups/sqlite/
# (auto-rotated, 10 per DB, refreshed on every `cleo session end`) plus
# on-demand full-4-file snapshots via `cleo backup add` / `cleo backup list`
# / `cleo restore backup`. See .cleo/adrs/ADR-013 for full rationale.
.cleo/tasks.db
.cleo/tasks.db-wal
.cleo/tasks.db-shm
.cleo/brain.db
.cleo/brain.db-wal
.cleo/brain.db-shm
.cleo/config.json
.cleo/project-info.json
.cleo/backups/
.cleo/logs/

# ---------------------------------------------------------------------------
# TypeScript compile artifacts — source dirs must ONLY contain .ts files.
# All emitted .js/.d.ts/.d.ts.map/.js.map belongs in each package's dist/.
# These patterns are intentionally broad to prevent recurrence.
# ---------------------------------------------------------------------------
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# Test artifacts anywhere in the monorepo
**/__tests__/**/*.js
**/__tests__/**/*.js.map
**/__tests__/**/*.d.ts
**/__tests__/**/*.d.ts.map
**/*.test.js
**/*.test.js.map
**/*.test.d.ts
**/*.test.d.ts.map

# Package-root / project-root config file compile artifacts
# (matches forge-ts.config.*, vitest.config.*, tsup.config.*, drizzle.config.*)
/forge-ts.config.js
/forge-ts.config.js.map
/forge-ts.config.d.ts
/forge-ts.config.d.ts.map
/vitest.config.js
/vitest.config.js.map
/vitest.config.d.ts
/vitest.config.d.ts.map
packages/*/forge-ts.config.js
packages/*/forge-ts.config.js.map
packages/*/forge-ts.config.d.ts
packages/*/forge-ts.config.d.ts.map
packages/*/vitest.config.js
packages/*/vitest.config.js.map
packages/*/vitest.config.d.ts
packages/*/vitest.config.d.ts.map
packages/*/tsup.config.js
packages/*/tsup.config.js.map
packages/*/tsup.config.d.ts
packages/*/tsup.config.d.ts.map
/drizzle/*.config.js
/drizzle/*.config.js.map
/drizzle/*.config.d.ts
/drizzle/*.config.d.ts.map

# Script file compile artifacts (scripts are .ts sources; compiled siblings are junk)
packages/*/scripts/**/*.js
packages/*/scripts/**/*.js.map
packages/*/scripts/**/*.d.ts
packages/*/scripts/**/*.d.ts.map

# Examples: .ts sources only; compiled siblings are junk
packages/*/examples/**/*.js
packages/*/examples/**/*.js.map
packages/*/examples/**/*.d.ts
packages/*/examples/**/*.d.ts.map

# Intentionally tracked hand-written files that match the patterns above
# (do NOT ignore these — they are the real entry points):
!packages/cleo/bin/postinstall.js
!packages/skills/index.js
!packages/skills/index.d.ts

# Misc noise
clawmsgr-agent.json
clawmsgr-*.json

# Rust build artifacts
target/
types.js

# Rust coverage
tarpaulin-report.json

# VS Code extension build artifacts
editors/vscode-cant/src/*.js
editors/vscode-cant/src/*.js.map
editors/vscode-cant/src/*.d.ts
editors/vscode-cant/src/*.d.ts.map
