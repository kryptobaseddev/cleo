          "type": "string",
          "minLength": 1
        },
        "advisory": {
          "type": "boolean"
        },
        "timeoutMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "kind": {
          "type": "string",
          "const": "command"
        },
        "cmd": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
