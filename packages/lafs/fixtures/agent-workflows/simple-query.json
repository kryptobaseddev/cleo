        "page": { "mode": "none" }
      }
    }
  ],
  "validationTests": {
    "validVariants": [
      {
        "name": "Standard flow",
        "description": "Normal 3-step weather query workflow"
      }
    ],
    "invalidVariants": [
      {
        "name": "Missing contextVersion increment",
        "description": "All envelopes have contextVersion: 1 - should fail validation",
        "modification": "Set all _meta.contextVersion to 1",
        "expectedFailure": "CONTEXT_VERSION_MISMATCH"
      },
      {
        "name": "Wrong operation sequence",
        "description": "Operations out of logical order",
        "modification": "Swap operation names: format before parse",
        "expectedFailure": "WORKFLOW_LOGIC_ERROR"
      }
    ]
  }
}
