{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AcceptanceGate",
  "description": "Machine-verifiable acceptance gate attached to a CLEO task",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "req": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "advisory": {
          "type": "boolean"
        },
        "timeoutMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "kind": {
          "type": "string",
          "const": "test"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expect": {
          "type": "string",
          "enum": [
            "pass",
            "exit0"
          ]
        },
        "minCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "description",
        "kind",
        "command",
        "expect"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "req": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
