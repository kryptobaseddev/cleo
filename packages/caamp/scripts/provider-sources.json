{
  "$schema": "./provider-sources.schema.json",
  "version": "1.0.0",
  "lastUpdated": "2026-03-02",
  "aggregateSources": [
    {
      "id": "vercel-skills",
      "name": "Vercel Labs Skills - agents.ts",
      "description": "Curated list of AI agent paths, instruction files, and skills directories",
      "urls": [
        "https://raw.githubusercontent.com/vercel-labs/skills/main/src/agents.ts"
      ],
      "provides": ["skillsPaths", "instructionFiles", "configPaths", "agentsList"]
    },
    {
      "id": "neon-add-mcp",
      "name": "Neon add-mcp - Agent detection and MCP config paths",
      "description": "Multi-agent MCP installer with config path detection for 15+ agents",
      "urls": [
        "https://raw.githubusercontent.com/neondatabase/add-mcp/main/src/agents.ts",
        "https://raw.githubusercontent.com/neondatabase/add-mcp/main/README.md"
      ],
      "provides": ["mcpConfigPaths", "configKeys", "detectionMethods", "supportedTransports"]
    }
  ],
