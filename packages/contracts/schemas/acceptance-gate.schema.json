          "type": "boolean"
        },
        "timeoutMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "kind": {
          "type": "string",
          "const": "manual"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
