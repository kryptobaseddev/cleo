initembeddingprovider", "callee": "initDefaultProvider", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L608"}, {"caller_nid": "store_memory_sqlite_probebraindbintegrity", "callee": "get", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L630"}, {"caller_nid": "store_memory_sqlite_probebraindbintegrity", "callee": "prepare", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L630"}, {"caller_nid": "store_memory_sqlite_ismalformationerror", "callee": "test", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L653"}, {"caller_nid": "store_memory_sqlite_openbraindbwithrecovery", "callee": "tryOpen", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L690"}, {"caller_nid": "store_memory_sqlite_openbraindbwithrecovery", "callee": "runRecovery", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L693"}, {"caller_nid": "store_memory_sqlite_openbraindbwithrecovery", "callee": "tryOpen", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L694"}, {"caller_nid": "store_memory_sqlite_openbraindbwithrecovery", "callee": "close", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L699"}, {"caller_nid": "store_memory_sqlite_openbraindbwithrecovery", "callee": "runRecovery", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L703"}, {"caller_nid": "store_memory_sqlite_openbraindbwithrecovery", "callee": "tryOpen", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L704"}, {"caller_nid": "store_memory_sqlite_getbraindb", "callee": "assertTestEnv", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L726"}, {"caller_nid": "store_memory_sqlite_getbraindb", "callee": "(async () => {\n    const dbPath = requestedPath;\n    _dbPath = dbPath;\n\n    // Ensure directory exists\n    mkdirSync(dirname(dbPath), { recursive: true });\n\n    // Open file-backed SQLite via node:sqlite with WAL mode.\n    // allowExtension: true enables sqlite-vec extension loading.\n    //\n    // T10303 (Saga T10281 / Epic T10286): wrap the open in malformation\n    // detection + auto-recovery. Catches both `ERR_SQLITE_ERROR errcode=11`\n    // (raised by the open itself or by the post-open quick_check probe)\n    // and silent schema corruption that surfaces during the first prepare()\n    // call. On detection, the corrupt DB is quarantined and the freshest\n    // validated snapshot is restored; we then re-attempt the open ONCE.\n    const nativeDb = openBrainDbWithRecovery(dbPath, cwd);\n    _nativeDb = nativeDb;\n\n    // Load sqlite-vec extension for vector similarity search (T5157).\n    // Non-fatal if unavailable \u2014 vec0 tables simply won't be created.\n    _vecLoaded = loadBrainVecExtension(nativeDb);\n\n    // Create drizzle ORM wrapper via node-sqlite\n    const db = drizzle({ client: nativeDb, schema: brainSchema });\n\n    // Run drizzle migrations (creates/updates tables)\n    runBrainMigrations(nativeDb, db);\n\n    // Create vec0 virtual table for embeddings if extension is loaded (T5157).\n    // Must run after migrations so the schema is consistent.\n    if (_vecLoaded) {\n      initializeBrainVec(nativeDb);\n    }\n\n    // Seed schema version for new databases (no-op if already set)\n    nativeDb\n      .prepare(\n        `INSERT OR IGNORE INTO brain_schema_meta (key, value) VALUES ('schemaVersion', '${BRAIN_SCHEMA_VERSION}')`,\n      )\n      .run();\n\n    // Set singleton only after migrations complete\n    _db = db;\n\n    // Wire the default embedding provider when vec is loaded and embedding is enabled.\n    // Best-effort, async, never blocks DB access. (T539)\n    if (_vecLoaded) {\n      setImmediate(() => {\n        initEmbeddingProvider(cwd).catch(() => {\n          // Non-fatal \u2014 embedding will be unavailable until next startup\n        });\n      });\n    }\n\n    return db;\n  })", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L738"}, {"caller_nid": "store_memory_sqlite_closebraindb", "callee": "close", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L810"}, {"caller_nid": "store_memory_sqlite_resetbraindbstate", "callee": "close", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/memory-sqlite.ts", "source_location": "L831"}]}