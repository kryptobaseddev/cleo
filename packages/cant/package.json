{
  "name": "@cleocode/cant",
  "version": "2026.4.45",
  "description": "CANT protocol parser and runtime for CLEO — wraps cant-core via napi-rs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "napi/"
  ],
  "scripts": {
    "build": "tsc",
    "build:napi": "cargo build --release -p cant-napi && mkdir -p napi && cp ../../target/release/libcant_napi.so napi/cant.linux-x64-gnu.node",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cleocode/contracts": "workspace:*",
    "@cleocode/core": "workspace:*",
    "@cleocode/lafs": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "napi": {
    "name": "cant",
    "package": {
      "name": "@cleocode/cant"
    },
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu"
      ]
    }
  },
  "keywords": [
    "cleo",
    "cant",
    "agent",
    "parser",
    "napi-rs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kryptobaseddev/cleo.git",
    "directory": "packages/cant"
  },
  "publishConfig": {
    "access": "public"
  }
}
