{
  "name": "@cleocode/core",
  "version": "2026.4.14",
  "description": "CLEO core business logic kernel — tasks, sessions, memory, orchestration, lifecycle, with bundled SQLite store",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./internal": {
      "import": "./dist/internal.js",
      "require": "./dist/internal.js",
      "types": "./dist/internal.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "require": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --include 'src/store/__tests__/*-integration.test.ts'"
  },
  "dependencies": {
    "@cleocode/adapters": "workspace:*",
    "@cleocode/agents": "workspace:*",
    "@cleocode/caamp": "workspace:*",
    "@cleocode/contracts": "workspace:*",
    "@cleocode/lafs": "workspace:*",
    "@cleocode/skills": "workspace:*",
    "@huggingface/transformers": "^4.0.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "drizzle-orm": "1.0.0-beta.19-d95b7a4",
    "env-paths": "^4.0.0",
    "js-tiktoken": "^1.0.21",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "proper-lockfile": "^4.1.2",
    "tar": "^7.4.3",
    "write-file-atomic": "^6.0.0",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-cli": "^0.26.7",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "migrations",
    "schemas",
    "templates",
    "src"
  ],
  "devDependencies": {
    "@types/proper-lockfile": "^4.1.4",
    "@types/tar": "^6.1.13",
    "@types/write-file-atomic": "^4.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kryptobaseddev/cleo",
    "directory": "packages/core"
  }
}
