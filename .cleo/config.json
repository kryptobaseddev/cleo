{
  "version": "2.10.0",
  "output": {
    "defaultFormat": "json",
    "showColor": true,
    "showUnicode": true,
    "dateFormat": "relative"
  },
  "backup": {
    "maxOperationalBackups": 10,
    "maxSafetyBackups": 5
  },
  "hierarchy": {
    "maxDepth": 3,
    "maxSiblings": 0,
    "maxActiveSiblings": 0
  },
  "session": {
    "autoStart": false,
    "multiSession": false
  },
  "lifecycle": {
    "mode": "strict"
  },
  "release": {
    "versionBump": {
      "files": [
        {
          "path": "VERSION",
          "strategy": "plain",
          "description": "Canonical version source of truth"
        },
        {
          "path": "package.json",
          "strategy": "json",
          "jsonPath": ".version",
          "description": "npm package version"
        }
      ]
    }
  },
  "contributor": {
    "isContributorProject": true,
    "devCli": "cleo-dev",
    "verifiedAt": "2026-03-07T00:00:00.000Z"
  }
}