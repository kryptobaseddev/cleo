{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Attachment",
  "description": "Content artifact (file, URL, blob, llms-txt, or llmtxt-doc) attachable to a CLEO owner",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kind": {
          "type": "string",
          "const": "local-file"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "mime": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "kind",
        "path",
        "sha256",
        "mime",
        "size"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kind": {
          "type": "string",
          "const": "url"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "cachedSha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "cachedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "mime": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "url"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kind": {
          "type": "string",
          "const": "blob"
        },
        "sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "storageKey": {
          "type": "string",
          "minLength": 1
        },
        "mime": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "kind",
        "sha256",
        "storageKey",
        "mime",
        "size"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kind": {
          "type": "string",
          "const": "llms-txt"
        },
        "source": {
          "type": "string",
          "enum": [
            "url",
            "generated"
          ]
        },
        "content": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        }
      },
      "required": [
        "kind",
        "source",
        "content",
        "sha256"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kind": {
          "type": "string",
          "const": "llmtxt-doc"
        },
        "slug": {
          "type": "string",
          "minLength": 1
        },
        "backend": {
          "type": "string",
          "enum": [
            "local",
            "remote"
          ]
        },
        "pinnedVersion": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "slug",
        "backend"
      ],
      "additionalProperties": false
    }
  ]
}
