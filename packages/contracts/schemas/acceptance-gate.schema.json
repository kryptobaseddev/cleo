          "type": "string",
          "minLength": 1
        },
        "attachmentSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "assertions": {
          "minItems": 1,
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "exists"
                  }
                },
                "required": [
                  "type"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "absent"
