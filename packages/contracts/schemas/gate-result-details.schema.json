{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GateResultDetails",
  "description": "Kind-specific detail payload for a GateResult — discriminated by kind",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "test"
        },
        "exitCode": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "duration": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "kind",
        "exitCode",
        "stdout",
        "stderr",
        "duration"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "file"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "passedAssertions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failedAssertions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "kind",
        "path",
        "passedAssertions",
        "failedAssertions"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "command"
        },
        "cmd": {
          "type": "string",
          "minLength": 1
        },
        "exitCode": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "stdout": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "cmd",
        "exitCode",
        "stdout"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "lint"
        },
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "warnings": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "errors": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "kind",
        "tool",
        "warnings",
        "errors"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "http"
        },
        "url": {
          "type": "string"
        },
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "body": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "url",
        "status",
        "body"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "manual"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "accepted": {
          "type": "boolean"
        }
      },
      "required": [
        "kind",
        "prompt",
        "accepted"
      ],
      "additionalProperties": false
    }
  ]
}
