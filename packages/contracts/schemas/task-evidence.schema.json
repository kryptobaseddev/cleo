          "minimum": 0,
          "maximum": 9007199254740991
        },
        "exitCode": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "sha256",
        "timestamp",
        "passed",
        "failed",
        "skipped",
        "exitCode"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "command-output"
        },
        "sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "cmd": {
          "type": "string",
          "minLength": 1
        },
        "exitCode": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "sha256",
        "timestamp",
        "cmd",
        "exitCode"
      ],
      "additionalProperties": false
