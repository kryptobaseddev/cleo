# Override root .gitignore which excludes dist/
# When .npmignore exists, .gitignore is not used for publish
src/**/__tests__
src/**/*.test.ts
*.tsbuildinfo
coverage/
.test-*
node_modules/

# Developer-side enforcement artifacts — never ship to consumers.
# See AGENTS.md "Skill Maintenance Discipline (Saga T9799 · Epic T9960)".
internal/
