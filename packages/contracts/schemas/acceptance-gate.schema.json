        },
        "stderrMatches": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "description",
        "kind",
        "cmd"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "req": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "advisory": {
          "type": "boolean"
        },
        "timeoutMs": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "kind": {
          "type": "string",
