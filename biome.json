{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "warn",
        "noUnusedFunctionParameters": "off"
      },
      "style": {
        "useImportType": "error",
        "useTemplate": "off",
        "useNodejsImportProtocol": "off",
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noControlCharactersInRegex": "off",
        "noConsole": {
          "level": "error",
          "options": {
            "allow": [
              "error",
              "warn",
              "info",
              "debug",
              "trace",
              "assert",
              "dir",
              "table",
              "time",
              "timeEnd",
              "timeLog",
              "group",
              "groupEnd",
              "groupCollapsed",
              "count",
              "countReset",
              "clear"
            ]
          }
        }
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "files": {
    "includes": [
      "packages/*/src/**/*.ts",
      "packages/*/__tests__/**/*.ts",
      "scripts/**/*.mjs",
      "scripts/**/*.ts"
    ]
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/__tests__/**", "**/__mocks__/**", "**/*.d.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noBannedTypes": "off"
          },
          "suspicious": {
            "noExplicitAny": "off",
            "noConsole": "off"
          },
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/cleo/src/dispatch/domains/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "error"
          }
        }
      }
    },
    {
      "includes": ["packages/cleo/src/cli/renderers/**", "packages/cleo/src/cli/help-renderer.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/adapters/src/**",
        "packages/caamp/src/**",
        "packages/cant/src/**",
        "packages/cleo-os/src/**",
        "packages/cleo/src/**",
        "packages/core/src/**",
        "packages/lafs/src/**",
        "packages/nexus/src/**",
        "scripts/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/core/src/lifecycle/consolidate-rcasd.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnreachable": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/cleo/src/cli/commands/workgraph.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["scripts/lint-envelope-compliance.mjs"],
      "linter": {
        "rules": {
          "suspicious": {
            "useIterableCallbackReturn": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/core/src/lifecycle/index.ts",
        "packages/core/src/scaffold/ensure-config.ts",
        "packages/core/src/scaffold/project-detection.ts"
      ],
      "linter": {
        "rules": {
          "correctness": {
            "noUnreachable": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/core/src/tasks/backfill-child-projections.ts",
        "packages/core/src/tasks/complete.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}
