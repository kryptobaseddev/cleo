, "callee": "close", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L138"}, {"caller_nid": "store_sqlite_autorecoverfrombackup", "callee": "warn", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L147"}, {"caller_nid": "store_sqlite_autorecoverfrombackup", "callee": "close", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L155"}, {"caller_nid": "store_sqlite_autorecoverfrombackup", "callee": "unlinkSync", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L161"}, {"caller_nid": "store_sqlite_autorecoverfrombackup", "callee": "unlinkSync", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L166"}, {"caller_nid": "store_sqlite_autorecoverfrombackup", "callee": "copyFileSync", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L173"}, {"caller_nid": "store_sqlite_autorecoverfrombackup", "callee": "renameSync", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L176"}, {"caller_nid": "store_sqlite_autorecoverfrombackup", "callee": "info", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L178"}, {"caller_nid": "store_sqlite_autorecoverfrombackup", "callee": "openNativeDatabase", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L184"}, {"caller_nid": "store_sqlite_autorecoverfrombackup", "callee": "drizzle", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L188"}, {"caller_nid": "store_sqlite_autorecoverfrombackup", "callee": "error", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L195"}, {"caller_nid": "store_sqlite_getdb", "callee": "(async () => {\n    const dbPath = requestedPath;\n    _dbPath = dbPath;\n\n    // Ensure directory exists\n    mkdirSync(dirname(dbPath), { recursive: true });\n\n    // Open file-backed SQLite via node:sqlite with WAL mode.\n    // openNativeDatabase is re-exported from sqlite-native.ts \u2014 the actual\n    // function lives there (zero CLEO imports) so the cycle cannot TDZ it.\n    const { openNativeDatabase } = await import('./sqlite-native.js');\n    const nativeDb = openNativeDatabase(dbPath);\n    _nativeDb = nativeDb;\n\n    // Create drizzle ORM wrapper via node-sqlite\n    const db = drizzle({ client: nativeDb, schema });\n\n    // Run drizzle migrations (creates/updates tables)\n    runMigrations(nativeDb, db);\n\n    // Migration SQL contains PRAGMA foreign_keys=ON statements.\n    // In test environments, disable FKs after migration to allow test\n    // fixtures to insert data without full referential integrity.\n    if (process.env.VITEST) {\n      nativeDb.exec('PRAGMA foreign_keys=OFF');\n    }\n\n    // Seed schema version for new databases (no-op if already set)\n    nativeDb.exec(\n      `INSERT OR IGNORE INTO schema_meta (key, value) VALUES ('schemaVersion', '${SCHEMA_VERSION}')`,\n    );\n    nativeDb.exec(\n      `INSERT OR IGNORE INTO schema_meta (key, value) VALUES ('task_id_sequence', '{\"counter\":0,\"lastId\":\"T000\",\"checksum\":\"seed\"}')`,\n    );\n\n    // Auto-recovery: detect empty database with available backups (T5188)\n    // Root cause: git-tracked WAL/SHM files get overwritten on branch switch,\n    // causing data loss when the WAL contained uncommitted writes.\n    await autoRecoverFromBackup(nativeDb, dbPath, cwd);\n\n    // Check if tasks.db or its WAL/SHM are dangerously tracked by git (ADR-013, T5158, T5188).\n    //\n    // As of ADR-013 \u00a79 (2026-04-07) the canonical resolution is:\n    //   1. `.cleo/tasks.db` + WAL/SHM and `.cleo/brain.db` + WAL/SHM are\n    //      git-ignored at the project root and untracked via `git rm --cached`.\n    //   2. Recovery is provided by VACUUM INTO snapshots in\n    //      `.cleo/backups/sqlite/` (auto-rotated, 10 per DB, refreshed on\n    //      every `cleo session end` via the backup-session-end hook).\n    //   3. Full 4-file snapshots (including config.json + project-info.json)\n    //      are created on demand via `cleo backup add` / listed via\n    //      `cleo backup list` / restored via `cleo restore backup`.\n    //\n    // The warning below is retained as a regression guard: if someone\n    // accidentally re-stages the DB into project git, this warning fires at\n    // every process startup so they fix it before real data loss occurs.\n    if (!_gitTrackingChecked) {\n      _gitTrackingChecked = true;\n      try {\n        const { execFileSync } = await import('node:child_process');\n        const gitCwd = resolve(dbPath, '..', '..');\n        const filesToCheck = [dbPath, dbPath + '-wal', dbPath + '-shm'];\n        const log = getLogger('sqlite');\n\n        for (const fileToCheck of filesToCheck) {\n          try {\n            execFileSync('git', ['ls-files', '--error-unmatch', fileToCheck], {\n              cwd: gitCwd,\n              stdio: 'pipe',\n            });\n            // If we get here, the file IS tracked \u2014 that's dangerous.\n            const basename = fileToCheck.split(/[\\\\/]/).pop();\n            const relPath = fileToCheck.replace(gitCwd + sep, '');\n            log.warn(\n              { path: fileToCheck },\n              `${basename} is tracked by project git \u2014 this risks data loss on branch switch. ` +\n                `Resolution (ADR-013 \u00a79): \\`git rm --cached ${relPath}\\` and rely on ` +\n                `\\`.cleo/backups/sqlite/\\` snapshots + \\`cleo backup add\\` for recovery.`,\n            );\n          } catch {\n            // Exit code 1 = not tracked = good\n          }\n        }\n      } catch {\n        // git not available, skip check\n      }\n    }\n\n    // Set singleton only after migrations complete\n    _db = db;\n    return db;\n  })", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L220"}, {"caller_nid": "store_sqlite_resolvemigrationsfolder", "callee": "resolveCorePackageMigrationsFolder", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L328"}, {"caller_nid": "store_sqlite_runmigrations", "callee": "tableExists", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L381"}, {"caller_nid": "store_sqlite_runmigrations", "callee": "createSafetyBackup", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L382"}, {"caller_nid": "store_sqlite_runmigrations", "callee": "reconcileJournal", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L386"}, {"caller_nid": "store_sqlite_runmigrations", "callee": "ensureColumns", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L393"}, {"caller_nid": "store_sqlite_runmigrations", "callee": "migrateWithRetry", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L398"}, {"caller_nid": "store_sqlite_runmigrations", "callee": "ensureColumns", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L401"}, {"caller_nid": "store_sqlite_closedb", "callee": "close", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L411"}, {"caller_nid": "store_sqlite_resetdbstate", "callee": "close", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L432"}, {"caller_nid": "store_sqlite_getschemaversion", "callee": "where", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L449"}, {"caller_nid": "store_sqlite_getschemaversion", "callee": "from", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L449"}, {"caller_nid": "store_sqlite_getschemaversion", "callee": "select", "is_member_call": true, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L449"}, {"caller_nid": "store_sqlite_getschemaversion", "callee": "eq", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L452"}, {"caller_nid": "store_sqlite_dbexists", "callee": "existsSync", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L461"}, {"caller_nid": "store_sqlite_closealldatabases", "callee": "closeBrainDb", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L503"}, {"caller_nid": "store_sqlite_closealldatabases", "callee": "closeNexusDb", "is_member_call": false, "source_file": "/mnt/projects/cleocode/packages/core/src/store/sqlite.ts", "source_location": "L511"}]}