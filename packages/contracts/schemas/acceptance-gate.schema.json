                  },
                  "value": {
                    "type": "string",
                    "minLength": 64,
                    "maxLength": 64
                  }
                },
                "required": [
                  "type",
                  "value"
                ],
                "additionalProperties": false
              }
            ]
          }
        }
      },
      "required": [
        "description",
        "kind",
        "assertions"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
