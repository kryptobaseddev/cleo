{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "warn",
        "noUnusedFunctionParameters": "off"
      },
      "style": {
        "useImportType": "error",
        "useTemplate": "off",
        "useNodejsImportProtocol": "off",
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noControlCharactersInRegex": "off",
        "noConsole": {
          "level": "error",
          "options": {
            "allow": [
              "error",
              "warn",
              "info",
              "debug",
              "trace",
              "assert",
              "dir",
              "table",
              "time",
              "timeEnd",
              "timeLog",
              "group",
              "groupEnd",
              "groupCollapsed",
              "count",
              "countReset",
              "clear"
            ]
          }
        }
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "files": {
    "includes": ["packages/*/src/**/*.ts", "packages/*/__tests__/**/*.ts", "scripts/**/*.mjs"]
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/__tests__/**", "**/__mocks__/**", "**/*.d.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noBannedTypes": "off"
          },
          "suspicious": {
            "noExplicitAny": "off",
            "noConsole": "off"
          },
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/cleo/src/dispatch/domains/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "error"
          }
        }
      }
    },
    {
      "includes": ["packages/cleo/src/cli/renderers/**", "packages/cleo/src/cli/help-renderer.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/adapters/src/**",
        "packages/caamp/src/**",
        "packages/cant/src/**",
        "packages/cleo-os/src/**",
        "packages/cleo/src/**",
        "packages/core/src/**",
        "packages/lafs/src/**",
        "packages/nexus/src/**",
        "scripts/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
