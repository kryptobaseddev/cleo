{
  "name": "@cleocode/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/contracts",
    "packages/core",
    "packages/cleoctl"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "npm run build -w packages/contracts && npm run build -w packages/core && npm run build -w packages/cleoctl",
    "build:contracts": "npm run build -w packages/contracts",
    "build:core": "npm run build -w packages/core",
    "build:cleoctl": "npm run build -w packages/cleoctl",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^22.19.11",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
