{
  "name": "cant-dsl",
  "displayName": "CANT DSL",
  "description": "Language support for CANT DSL (.cant files)",
  "version": "0.1.0",
  "publisher": "cleocode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cleocode/cleocode"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "cant",
        "aliases": [
          "CANT",
          "cant"
        ],
        "extensions": [
          ".cant"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cant",
        "scopeName": "source.cant",
        "path": "./syntaxes/cant.tmLanguage.json"
      }
    ]
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:cant"
  ],
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0"
  }
}
