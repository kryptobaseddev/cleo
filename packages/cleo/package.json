{
  "name": "@cleocode/cleo",
  "version": "2026.3.64",
  "description": "CLEO CLI + MCP server — the assembled product consuming @cleocode/core",
  "type": "module",
  "main": "./dist/cli/index.js",
  "exports": {
    ".": "./dist/cli/index.js",
    "./mcp": "./dist/mcp/index.js"
  },
  "bin": {
    "cleo": "dist/cli/index.js",
    "ct": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "postinstall": "node bin/postinstall.js"
  },
  "dependencies": {
    "@cleocode/caamp": "^1.8.1",
    "@cleocode/contracts": "workspace:*",
    "@cleocode/core": "workspace:*",
    "@cleocode/lafs-protocol": "^1.8.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "citty": "^0.2.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "migrations",
    "completions",
    "bin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kryptobaseddev/cleo",
    "directory": "packages/cleo"
  }
}
