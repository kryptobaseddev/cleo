{
  "name": "@cleocode/monorepo",
  "version": "2026.4.117",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:types": "tsc -b",
    "build:contracts": "pnpm -r --filter @cleocode/contracts run build",
    "build:core": "pnpm -r --filter @cleocode/core run build",
    "build:cleo": "pnpm -r --filter @cleocode/cleo run build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:cleo-errors": "node scripts/lint-cleo-errors.mjs",
    "docs:check": "forge-ts check",
    "docs:test": "forge-ts test",
    "docs:build": "forge-ts build",
    "docs:init": "forge-ts docs init --target mintlify --out-dir docs/site",
    "docs:dev": "forge-ts docs dev",
    "clean": "find packages -type d -name dist -prune -exec rm -rf {} + && find packages -name '*.tsbuildinfo' -delete",
    "clean:node-modules": "find packages -type d -name node_modules -prune -exec rm -rf {} + && rm -rf node_modules && pnpm install",
    "db:generate": "drizzle-kit generate --config drizzle/tasks.config.ts",
    "db:generate:brain": "drizzle-kit generate --config drizzle/brain.config.ts",
    "db:generate:nexus": "drizzle-kit generate --config drizzle/nexus.config.ts",
    "db:generate:custom": "drizzle-kit generate --custom --config drizzle/tasks.config.ts",
    "db:new": "node scripts/new-migration.mjs",
    "db:check": "for cfg in drizzle/tasks.config.ts drizzle/brain.config.ts drizzle/nexus.config.ts drizzle/signaldock.config.ts drizzle/telemetry.config.ts; do node_modules/.bin/drizzle-kit check --config=$cfg || exit 1; done",
    "db:studio": "drizzle-kit studio --config drizzle/tasks.config.ts",
    "db:studio:brain": "drizzle-kit studio --config drizzle/brain.config.ts",
    "db:studio:nexus": "drizzle-kit studio --config drizzle/nexus.config.ts",
    "test:install-scenarios": "node scripts/wave3-install-scenarios.mjs",
    "version:check": "node scripts/check-version-sync.mjs",
    "version:bump": "node scripts/version-all.mjs",
    "cleo:dev": "node --disable-warning=ExperimentalWarning packages/cleo/dist/cli/index.js"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "darwin",
        "linux",
        "win32"
      ],
      "cpu": [
        "x64",
        "arm64"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "@biomejs/biome",
      "tree-sitter",
      "tree-sitter-c",
      "tree-sitter-cpp",
      "tree-sitter-go",
      "tree-sitter-java",
      "tree-sitter-javascript",
      "tree-sitter-python",
      "tree-sitter-ruby",
      "tree-sitter-rust",
      "tree-sitter-typescript"
    ],
    "overrides": {
      "path-to-regexp": ">=8.4.2",
      "brace-expansion": ">=2.0.3",
      "picomatch": ">=4.0.4",
      "esbuild": ">=0.25.0",
      "yaml": ">=2.8.3",
      "vite": "^8.0.8",
      "global-agent": "^4.1.3"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@changesets/cli": "^2.30.0",
    "@codluv/versionguard": "1.2.0",
    "@forge-ts/cli": "^0.19.5",
    "@forge-ts/core": "^0.6.6",
    "@rollup/rollup-linux-x64-gnu": "^4.60.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.19.11",
    "drizzle-kit": "1.0.0-beta.19-d95b7a4",
    "esbuild": "^0.28.0",
    "svelte": "^5.28.1",
    "typescript": "6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@cleocode/caamp": "workspace:*",
    "@cleocode/lafs": "workspace:*",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "drizzle-orm": "1.0.0-beta.22-ec7b61d",
    "env-paths": "^4.0.0",
    "js-tiktoken": "^1.0.21",
    "llmtxt": "^2026.4.9",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "proper-lockfile": "^4.1.2",
    "write-file-atomic": "^7.0.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
