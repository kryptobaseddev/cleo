#!/bin/bash
# HARD GUARD: Reject commits from non-owner git identities.
# This prevents worker agents from committing as "test" or other
# non-canonical identities. Only kryptobaseddev-owned emails pass.
# To override (emergency only): GIT_AUTHOR_OVERRIDE=1 git commit ...

ALLOWED_EMAILS=(
    "kryptobaseddev@users.noreply.github.com"
    "kryptokeaton@gmail.com"
    "keatonhoskins@gmail.com"
    "95310582+kryptobaseddev@users.noreply.github.com"
)

author_email=$(git config user.email)
committer_email=$(git config user.email)

# Check author
allowed=false
for email in "${ALLOWED_EMAILS[@]}"; do
    if [ "$author_email" = "$email" ]; then
        allowed=true
        break
    fi
done

if [ "$allowed" = false ]; then
    echo "================================================"
    echo "  COMMIT REJECTED: non-canonical git identity"
    echo "================================================"
    echo "  user.email = $author_email"
    echo "  Expected one of: ${ALLOWED_EMAILS[*]}"
    echo ""
    echo "  Fix: git config user.email 'kryptobaseddev@users.noreply.github.com'"
    echo "  Emergency override: GIT_AUTHOR_OVERRIDE=1 git commit ..."
    echo "================================================"
    exit 1
fi

exit 0
