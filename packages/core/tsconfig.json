{
  "compilerOptions": {
    "target": "ES2025",
    "module": "NodeNext",
    "lib": ["ES2025"],
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "isolatedModules": true,
    "composite": true
  },
  "references": [
    { "path": "../contracts" },
    { "path": "../lafs" },
    { "path": "../caamp" },
    { "path": "../nexus" },
    { "path": "../worktree" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/**/__tests__", "src/**/*.test.ts"]
}
