{
  "name": "@cleocode/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:types": "tsc -b",
    "build:contracts": "pnpm -r --filter @cleocode/contracts run build",
    "build:core": "pnpm -r --filter @cleocode/core run build",
    "build:cleoctl": "pnpm -r --filter @cleocode/cleoctl run build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf packages/*/dist"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@biomejs/biome"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^22.19.11",
    "drizzle-kit": "1.0.0-beta.18-7eb39f0",
    "esbuild": "^0.27.4",
    "typescript": "6.0.1-rc",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21",
    "zod": "^3.25.76"
  }
}
