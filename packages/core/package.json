{
  "name": "@cleocode/core",
  "version": "2026.4.98",
  "description": "CLEO core business logic kernel — tasks, sessions, memory, orchestration, lifecycle, with bundled SQLite store",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/cleo.d.ts",
      "import": "./dist/cleo.js",
      "require": "./dist/cleo.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "require": "./dist/internal.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js",
      "require": "./dist/contracts.js"
    },
    "./tasks": {
      "types": "./dist/tasks/index.d.ts",
      "import": "./dist/tasks/index.js",
      "require": "./dist/tasks/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js",
      "require": "./dist/memory/index.js"
    },
    "./sessions": {
      "types": "./dist/sessions/index.d.ts",
      "import": "./dist/sessions/index.js",
      "require": "./dist/sessions/index.js"
    },
    "./nexus": {
      "types": "./dist/nexus/index.d.ts",
      "import": "./dist/nexus/index.js",
      "require": "./dist/nexus/index.js"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle/index.d.ts",
      "import": "./dist/lifecycle/index.js",
      "require": "./dist/lifecycle/index.js"
    },
    "./conduit": {
      "types": "./dist/conduit/index.d.ts",
      "import": "./dist/conduit/index.js",
      "require": "./dist/conduit/index.js"
    },
    "./store/*": {
      "types": "./dist/store/*.d.ts",
      "import": "./dist/store/*.js",
      "require": "./dist/store/*.js"
    },
    "./conduit/*": {
      "types": "./dist/conduit/*.d.ts",
      "import": "./dist/conduit/*.js",
      "require": "./dist/conduit/*.js"
    },
    "./tasks/*": {
      "types": "./dist/tasks/*.d.ts",
      "import": "./dist/tasks/*.js",
      "require": "./dist/tasks/*.js"
    },
    "./lifecycle/*": {
      "types": "./dist/lifecycle/*.d.ts",
      "import": "./dist/lifecycle/*.js",
      "require": "./dist/lifecycle/*.js"
    },
    "./memory/*": {
      "types": "./dist/memory/*.d.ts",
      "import": "./dist/memory/*.js",
      "require": "./dist/memory/*.js"
    },
    "./sessions/*": {
      "types": "./dist/sessions/*.d.ts",
      "import": "./dist/sessions/*.js",
      "require": "./dist/sessions/*.js"
    },
    "./nexus/*": {
      "types": "./dist/nexus/*.d.ts",
      "import": "./dist/nexus/*.js",
      "require": "./dist/nexus/*.js"
    },
    "./memory/transcript-scanner.js": {
      "types": "./dist/memory/transcript-scanner.d.ts",
      "import": "./dist/memory/transcript-scanner.js",
      "require": "./dist/memory/transcript-scanner.js"
    },
    "./memory/transcript-extractor.js": {
      "types": "./dist/memory/transcript-extractor.d.ts",
      "import": "./dist/memory/transcript-extractor.js",
      "require": "./dist/memory/transcript-extractor.js"
    },
    "./memory/precompact-flush.js": {
      "types": "./dist/memory/precompact-flush.d.ts",
      "import": "./dist/memory/precompact-flush.js",
      "require": "./dist/memory/precompact-flush.js"
    },
    "./memory/brain-backfill.js": {
      "types": "./dist/memory/brain-backfill.d.ts",
      "import": "./dist/memory/brain-backfill.js",
      "require": "./dist/memory/brain-backfill.js"
    },
    "./system/platform-paths.js": {
      "types": "./dist/system/platform-paths.d.ts",
      "import": "./dist/system/platform-paths.js",
      "require": "./dist/system/platform-paths.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --include 'src/store/__tests__/*-integration.test.ts'"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@anthropic-ai/sdk": "^0.88.0",
    "@cleocode/adapters": "workspace:*",
    "@cleocode/agents": "workspace:*",
    "@cleocode/caamp": "workspace:*",
    "@cleocode/contracts": "workspace:*",
    "@cleocode/lafs": "workspace:*",
    "@cleocode/nexus": "workspace:*",
    "@cleocode/skills": "workspace:*",
    "@huggingface/transformers": "^4.0.1",
    "ai": "^6.0.162",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "drizzle-orm": "1.0.0-beta.22-ec7b61d",
    "env-paths": "^4.0.0",
    "js-tiktoken": "^1.0.21",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "proper-lockfile": "^4.1.2",
    "sqlite-vec": "^0.1.9",
    "tar": "^7.4.3",
    "tree-sitter": "0.21.1",
    "tree-sitter-c": "0.23.2",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-python": "0.23.4",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "write-file-atomic": "^7.0.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "migrations",
    "schemas",
    "templates",
    "src"
  ],
  "devDependencies": {
    "@types/proper-lockfile": "^4.1.4",
    "@types/tar": "^6.1.13",
    "@types/write-file-atomic": "^4.0.3",
    "better-sqlite3": "^12.4.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kryptobaseddev/cleo",
    "directory": "packages/core"
  },
  "optionalDependencies": {
    "llmtxt": "^2026.4.9"
  },
  "peerDependencies": {
    "better-sqlite3": "*"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  }
}
